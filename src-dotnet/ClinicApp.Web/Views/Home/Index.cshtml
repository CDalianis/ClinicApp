@{
    ViewData["Title"] = "ClinicApp";
}

<div class="container py-4">
    <div class="p-4 p-md-5 mb-4 rounded text-bg-dark">
        <div class="col-md-8 px-0">
            <h1 class="display-5 fw-bold">ClinicApp</h1>
            <p class="lead my-3">A server-rendered clinic management app for doctors, users, roles, and capability-based authorization.</p>
            <p class="lead mb-0">
                <a class="btn btn-primary" asp-controller="Doctors" asp-action="Index">View doctors</a>
            </p>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Login</h5>
                    <p class="card-text">Sign in to access protected actions.</p>
                    <a class="btn btn-outline-primary" href="/login">Go to login</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Register</h5>
                    <p class="card-text">Create a user account (role selection depends on your permissions).</p>
                    <a class="btn btn-outline-primary" asp-controller="Users" asp-action="Register">Register</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Logs</h5>
                    <p class="card-text">Rolling files are written under <code>./logs</code> (all/error/sql).</p>
                </div>
            </div>
        </div>
    </div>
</div>
