@model ClinicApp.Web.Infrastructure.PagedResult<ClinicApp.Web.Models.Doctor>
@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">Doctors</h2>
    <a class="btn btn-primary" asp-action="Insert">New doctor</a>
</div>

@if (TempData["ErrorMessage"] is string errorMsg && !string.IsNullOrWhiteSpace(errorMsg))
{
    <div class="alert alert-danger">@errorMsg</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Last name</th>
            <th>First name</th>
            <th>License #</th>
            <th>Region</th>
            <th style="width: 190px;"></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var d in Model.Items)
        {
            <tr>
                <td>@d.LastName</td>
                <td>@d.FirstName</td>
                <td><code>@d.LicenseNumber</code></td>
                <td>@d.Region?.Name</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-uuid="@d.Uuid">Edit</a>
                    <form method="post" asp-action="Delete" asp-route-uuid="@d.Uuid" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete this doctor?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<nav class="d-flex justify-content-between align-items-center">
    <div class="text-muted">
        Page <strong>@(Model.PageIndex + 1)</strong> of <strong>@(Math.Max(Model.TotalPages, 1))</strong> —
        Total <strong>@Model.TotalCount</strong>
    </div>
    <ul class="pagination mb-0">
        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-size="@Model.PageSize">Previous</a>
        </li>
        <li class="page-item @(Model.HasNext ? "" : "disabled")">
            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-size="@Model.PageSize">Next</a>
        </li>
    </ul>
</nav>

