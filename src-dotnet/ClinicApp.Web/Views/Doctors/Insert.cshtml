@model ClinicApp.Web.ViewModels.Doctors.DoctorInsertViewModel
@{
    ViewData["Title"] = "Create doctor";
    var regions = (List<SelectListItem>?)ViewData["Regions"] ?? new();
}

<h2 class="mb-3">Create doctor</h2>

<form method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LicenseNumber" class="form-label"></label>
            <input asp-for="LicenseNumber" class="form-control" />
            <span asp-validation-for="LicenseNumber" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="RegionId" class="form-label">Region</label>
            <select asp-for="RegionId" class="form-select" asp-items="regions">
                <option value="">Select a region...</option>
            </select>
            <span asp-validation-for="RegionId" class="text-danger"></span>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Create</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

