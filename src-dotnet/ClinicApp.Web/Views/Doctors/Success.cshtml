@{
    ViewData["Title"] = "Doctor created";
    var uuid = TempData["DoctorUuid"] as string;
}

<div class="alert alert-success">
    <h4 class="alert-heading">Doctor created successfully</h4>
    @if (!string.IsNullOrWhiteSpace(uuid))
    {
        <p class="mb-0"><strong>UUID:</strong> <code>@uuid</code></p>
    }
</div>

<div class="mt-3">
    <a class="btn btn-primary" asp-action="Index">Back to list</a>
</div>

